# OpenAlgon — Environment Variables Template
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to git — it is already in .gitignore

# ─────────────────────────────────────────────────────────────
# SUPABASE
# Get these from: https://supabase.com/dashboard → Project → Settings → API
# ─────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ─────────────────────────────────────────────────────────────
# SUPABASE — Required Table Setup
# Run this SQL in your Supabase SQL Editor:
#
# create table if not exists public.contact_submissions (
#   id uuid default gen_random_uuid() primary key,
#   name text not null,
#   email text not null,
#   company text,
#   message text not null,
#   created_at timestamptz default now() not null
# );
#
# -- Enable Row Level Security
# alter table public.contact_submissions enable row level security;
#
# -- Allow anonymous inserts (for the contact form)
# create policy "Allow public inserts" on public.contact_submissions
#   for insert with check (true);
#
# -- Only authenticated users (your team) can read submissions
# create policy "Allow authenticated reads" on public.contact_submissions
#   for select using (auth.role() = 'authenticated');
# ─────────────────────────────────────────────────────────────
